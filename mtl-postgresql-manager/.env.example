# =============================================================================
# MTL PostgreSQL Manager - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update the values for your environment
#
# Cách sử dụng:
#   Development: cp .env.example .env (dùng với docker-compose.yml)
#   Production:  cp .env.example .env (dùng với docker-compose.prod.yml)
#
# Quan trọng: THAY ĐỔI tất cả password bằng giá trị bảo mật!
# =============================================================================

# =============================================================================
# DOCKER HUB IMAGE (Production)
# =============================================================================
# Image từ Docker Hub để pull (dùng trong docker-compose.prod.yml)
DOCKERHUB_IMAGE=quangthai87/mtl-postgresql-manager
IMAGE_TAG=latest

# =============================================================================
# DATABASE (SQLite cho metadata)
# =============================================================================
# Đường dẫn database SQLite trong container (KHÔNG thay đổi)
DATABASE_URL=file:/data/mtl-manager.db

# =============================================================================
# POSTGRESQL CONNECTION
# =============================================================================
# Thông tin kết nối đến PostgreSQL container
POSTGRES_HOST=mtl-postgresql
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_secure_password
POSTGRES_DB=postgres

# =============================================================================
# SESSION
# =============================================================================
# Secret key cho session (nên dùng chuỗi ngẫu nhiên >= 32 ký tự)
SESSION_SECRET=change_this_to_random_secret_key_minimum_32_characters

# =============================================================================
# APPLICATION
# =============================================================================
# URL của ứng dụng (thay đổi nếu deploy production)
NEXT_PUBLIC_APP_URL=http://localhost:7001

# =============================================================================
# ADMIN CREDENTIALS - MTL Manager App
# =============================================================================
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change_this_to_secure_password

# =============================================================================
# ADMIN CREDENTIALS - pgAdmin4
# =============================================================================
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_this_to_secure_password

# =============================================================================
# EXTERNAL PORTS (Tùy chọn - Production)
# =============================================================================
# Bỏ comment và thay đổi nếu muốn đổi port mặc định
# POSTGRES_EXTERNAL_PORT=7000
# MANAGER_EXTERNAL_PORT=7001
# PGADMIN_EXTERNAL_PORT=7002
