# =============================================================================
# MTL PostgreSQL Manager - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update the values for your environment

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="file:/data/mtl-manager.db"

# =============================================================================
# POSTGRESQL CONNECTION
# =============================================================================
POSTGRES_HOST=mtl-postgresql
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=postgres

# =============================================================================
# SESSION
# =============================================================================
SESSION_SECRET=mtl_manager_secret_key_change_in_production

# =============================================================================
# APPLICATION
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:7001

# =============================================================================
# ADMIN CREDENTIALS
# =============================================================================
# MTL Manager App - Login credentials
ADMIN_USERNAME=xxxxx
ADMIN_PASSWORD=xxxxx

# pgAdmin4 - Login credentials
PGADMIN_DEFAULT_EMAIL=xxx@xx.xx
PGADMIN_PASSWORD=xxxxx
